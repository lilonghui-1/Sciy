# ============================================================
# 库存管理系统 - 环境变量配置模板
# 使用方式: 复制此文件为 .env 并填写实际值
#   cp .env.example .env
# ============================================================

# ----------------------------------------------------------
# 应用基础配置
# ----------------------------------------------------------
# 应用名称
APP_NAME=库存管理系统
# 运行环境: development / staging / production
APP_ENV=development
# 密钥钥（用于 JWT 签名、加密等，生产环境务必修改！）
SECRET_KEY=change-me-to-a-random-secret-key-in-production

# ----------------------------------------------------------
# 数据库配置 (TimescaleDB / PostgreSQL)
# ----------------------------------------------------------
# 异步数据库连接 URL（SQLAlchemy async 引擎使用 asyncpg 驱动）
DATABASE_URL=postgresql+asyncpg://inventory_user:inventory_secret_password@db:5432/inventory_db
# 同步数据库连接 URL（Alembic 迁移、Celery 等同步场景使用 psycopg2 驱动）
DATABASE_SYNC_URL=postgresql+psycopg2://inventory_user:inventory_secret_password@db:5432/inventory_db

# ----------------------------------------------------------
# Redis 配置
# ----------------------------------------------------------
# Redis 连接 URL（用于缓存、Celery 消息代理、会话存储）
REDIS_URL=redis://redis:6379/0

# ----------------------------------------------------------
# JWT 认证配置
# ----------------------------------------------------------
# JWT 访问令牌有效期（分钟）
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
# JWT 刷新令牌有效期（天）
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
# JWT 算法
JWT_ALGORITHM=HS256

# ----------------------------------------------------------
# OpenAI API 配置（AI 智能分析功能）
# ----------------------------------------------------------
# OpenAI API 密钥（用于库存预测、智能补货建议等 AI 功能）
OPENAI_API_KEY=sk-your-openai-api-key-here
# OpenAI 模型名称
OPENAI_MODEL=gpt-4o

# ----------------------------------------------------------
# ERP 系统对接配置
# ----------------------------------------------------------
# ERP 系统 API 地址
ERP_API_URL=https://erp.example.com/api/v1
# ERP 系统 API 密钥
ERP_API_KEY=your-erp-api-key-here
# ERP 系统租户 ID
ERP_TENANT_ID=default-tenant
# ERP 数据同步间隔（秒）
ERP_SYNC_INTERVAL=300

# ----------------------------------------------------------
# SMTP 邮件服务配置（用于发送库存预警、报表等邮件）
# ----------------------------------------------------------
# SMTP 服务器地址
SMTP_HOST=smtp.example.com
# SMTP 服务器端口
SMTP_PORT=465
# SMTP 用户名
SMTP_USER=noreply@example.com
# SMTP 密码
SMTP_PASSWORD=your-smtp-password-here
# 发件人邮箱地址
SMTP_FROM=noreply@example.com
# 收件人列表（逗号分隔，用于库存预警通知）
SMTP_RECEIVERS=admin@example.com,manager@example.com
# 是否使用 SSL
SMTP_SSL=true
# 是否使用 TLS
SMTP_TLS=false

# ----------------------------------------------------------
# Twilio 短信服务配置（用于发送紧急库存预警短信）
# ----------------------------------------------------------
# Twilio 账户 SID
TWILIO_ACCOUNT_SID=your-twilio-account-sid
# Twilio 认证令牌
TWILIO_AUTH_TOKEN=your-twilio-auth-token
# Twilio 发送号码
TWILIO_FROM_NUMBER=+1234567890
# 短信接收号码（逗号分隔）
TWILIO_TO_NUMBERS=+1234567891,+1234567892

# ----------------------------------------------------------
# Webhook 配置（用于接收外部系统回调）
# ----------------------------------------------------------
# Webhook 接收地址（外部系统回调时使用此 URL）
WEBHOOK_URL=https://your-domain.com/api/v1/webhooks/inventory
# Webhook 签名密钥（用于验证回调请求的真实性）
WEBHOOK_SECRET=your-webhook-signing-secret

# ----------------------------------------------------------
# 前端构建变量（Vite 环境变量，必须以 VITE_ 开头）
# ----------------------------------------------------------
# 后端 API 基础地址
VITE_API_BASE_URL=/api/v1
# WebSocket 连接地址
VITE_WS_URL=ws://localhost:8000/ws
